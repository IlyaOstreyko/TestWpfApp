<Window x:Class="TestWpfApp.Views.AdminGroupsDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestWpfApp.Views"
        mc:Ignorable="d"
        Title="Управление группами и специальностями" 
        Height="1000" Width="1200"
        WindowStyle="None"      
        AllowsTransparency="True" 
        WindowState ="Maximized"
        WindowStartupLocation="CenterScreen">
    <Window.Template>
        <ControlTemplate TargetType="Window">
            <Border Name="newBorder" CornerRadius="2" BorderBrush="#FF0C9A28" BorderThickness="5">
                <Border.Background>
                    <ImageBrush ImageSource="/main.jpg" Stretch="UniformToFill"/>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{TemplateBinding Title}" Opacity="0.8" FontSize="24" FontWeight="Bold" 
                               HorizontalAlignment="Center" Background="White" Padding="20,5" Margin="0,10,0,0"/>
                    <Border Grid.Row="1" Margin="10">
                        <ContentPresenter />
                    </Border>
                </Grid>
            </Border>
        </ControlTemplate>
    </Window.Template>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <Style TargetType="GroupBox">
            <Setter Property="Background" Value="#CCFFFFFF" />
            <Setter Property="BorderBrush" Value="#FF0C9A28" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="60" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="1.25*" />
            </Grid.ColumnDefinitions>

            <!-- Левая часть: группы -->
            <GroupBox Grid.Column="0">
                <GroupBox.Header>
                    <TextBlock Text="ГРУППЫ" FontWeight="Bold" Margin="0,15,0,0"/>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ListBox ItemsSource="{Binding Groups}" 
                             SelectedItem="{Binding SelectedGroup}"
                             DisplayMemberPath="Name" 
                             FontSize="14" Margin="0,5"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Добавить" Command="{Binding AddGroupCommand}" 
                                Style="{StaticResource crud_button_template}" Width="100" Margin="5"/>
                        <Button Content="Удалить" Command="{Binding DeleteGroupCommand}" 
                                Style="{StaticResource crud_button_template}" Width="100" Margin="5"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <!-- Правая часть: Cпециальности выбранной Группы -->
            <GroupBox Grid.Column="1">
                <GroupBox.Header>
                    <TextBlock Text="СПЕЦИАЛЬНОСТИ В ГРУППЕ" FontWeight="Bold" Margin="0,15,0,0"/>
                </GroupBox.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Доступные специальности для привязки:" FontWeight="Normal" Margin="0,0,0,5"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding AvailableSpec}" Margin="0,5">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding NameSpeciality}" 
                                          IsChecked="{Binding IsLinked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                          Command="{Binding DataContext.ToggleSpecLinkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                          CommandParameter="{Binding}"
                                          FontSize="14" Margin="2"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Grid.Row="2" Text="* Отметьте специальности галочками для привязки" 
                               FontSize="10" FontStyle="Italic" Foreground="DarkGreen" HorizontalAlignment="Center"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- Нижняя панель -->
        <Grid Grid.Row="1" Background="#55000000">
            <Button HorizontalAlignment="Right" Margin="10" 
                    Style="{StaticResource close_button_template}" 
                    Click="CloseClick" Width="120">
                <TextBlock Text=" Назад " />
            </Button>
        </Grid>
    </Grid>
</Window>
